{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend-api",
      "runtimeExecutable": "venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "api.main:app", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173
    },
    {
      "name": "streamlit-app",
      "runtimeExecutable": "venv/bin/python",
      "runtimeArgs": ["-m", "streamlit", "run", "app/app.py", "--server.port", "8501", "--server.headless", "true"],
      "port": 8501
    }
  ]
}
